{
  "manifest_version": 3,
  "name": "No Tilt Chess",
  "version": "1.0.0",
  "description": "Set a daily defeat limit on Chess.com and lock the site until tomorrow once you reach it.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["*://chess.com/*", "*://*.chess.com/*"],
  "homepage_url": "https://github.com/NgrimaldiN/extension-chrome-chess",
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "No Tilt Chess",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png"
    },
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://chess.com/*", "*://*.chess.com/*"],
      "js": ["src/content/entry.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/bootstrap.js",
        "src/shared/chess-url.js",
        "src/shared/content-detection.js",
        "src/shared/date.js",
        "src/shared/daily-limit.js",
        "src/shared/lock-state.js",
        "src/shared/loss-signals.js"
      ],
      "matches": ["*://chess.com/*", "*://*.chess.com/*"]
    }
  ]
}
